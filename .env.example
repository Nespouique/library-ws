# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=Library

# API Configuration
LIST_PER_PAGE=10
PORT=3000

# Environment (development/production)
NODE_ENV=development

# CORS Configuration (optional - if you need to restrict origins)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,https://your-frontend-domain.com

# API Authentication (OIDC/JWKS)
# Keep AUTH_ENABLED unset or false to preserve unauthenticated local behavior.
AUTH_ENABLED=false
OIDC_ISSUER_URL=https://auth.example.com/realms/library
OIDC_JWKS_URI=https://auth.example.com/realms/library/protocol/openid-connect/certs
OIDC_AUDIENCE=library-ws
OIDC_REQUIRED_READ_SCOPE=library:read
OIDC_REQUIRED_WRITE_SCOPE=library:write

# API Gateway / token injector
GATEWAY_PORT=8080
TARGET_API_URL=http://library-ws:3000
OIDC_TOKEN_URL=https://auth.example.com/realms/library/protocol/openid-connect/token
OIDC_CLIENT_ID=library-ihm
# Prefer OIDC_CLIENT_SECRET_FILE when using Docker secrets.
OIDC_CLIENT_SECRET=change-me-server-side-only
# OIDC_CLIENT_SECRET_FILE=/run/secrets/library_ihm_client_secret
OIDC_SCOPE=library:read library:write
TOKEN_REFRESH_MARGIN_SECONDS=30
GATEWAY_REQUEST_TIMEOUT_MS=30000
GATEWAY_BODY_LIMIT=25mb
